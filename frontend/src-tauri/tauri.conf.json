{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "IT Assets",
  "version": "1.0.0",
  "identifier": "com.icc.itassets",
  "build": {
    "frontendDist": "../dist/frontend/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build:mobile"
  },
  "app": {
    "windows": [
      {
        "title": "IT Assets Inventory",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' http: https: data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
